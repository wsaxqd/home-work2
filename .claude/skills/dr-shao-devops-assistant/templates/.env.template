# 环境变量模板
# 复制此文件为 .env 并填入实际值

# ==================== 应用配置 ====================
# 应用版本号（用于镜像标签）
VERSION=1.0.0

# 环境类型
NODE_ENV=production

# ==================== 域名配置 ====================
DOMAIN=example.com
WWW_DOMAIN=www.example.com

# ==================== 数据库配置 ====================
# 数据库类型（postgres/mysql/mongodb）
DB_TYPE=postgres

# 数据库连接信息
DB_HOST=database
DB_PORT=5432
DB_NAME=myapp
DB_USER=dbuser
DB_PASSWORD=change_this_password

# 完整数据库 URL
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ==================== 应用密钥 ====================
# JWT 密钥（用于身份验证）
JWT_SECRET=change_this_to_random_string

# 会话密钥
SESSION_SECRET=change_this_to_random_string

# API 密钥（如果需要）
API_KEY=your_api_key_here

# ==================== 第三方服务 ====================
# 阿里云 OSS（如果使用）
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_OSS_BUCKET=
# ALIYUN_OSS_REGION=

# 腾讯云 COS（如果使用）
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=
# TENCENT_COS_BUCKET=
# TENCENT_COS_REGION=

# 微信小程序（如果使用）
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=

# ==================== SSL 证书路径 ====================
SSL_CERT_PATH=/etc/letsencrypt/live/${DOMAIN}/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/${DOMAIN}/privkey.pem

# ==================== 镜像仓库 ====================
# 腾讯云镜像仓库
REGISTRY_URL=ccr.ccs.tencentyun.com/your-namespace

# 镜像名称
BACKEND_IMAGE=${REGISTRY_URL}/backend:${VERSION}
FRONTEND_IMAGE=${REGISTRY_URL}/frontend:${VERSION}

# ==================== 日志配置 ====================
LOG_LEVEL=info
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3

# ==================== 端口配置 ====================
HTTP_PORT=80
HTTPS_PORT=443
BACKEND_PORT=3000

# ==================== 其他配置 ====================
# 时区
TZ=Asia/Shanghai

# 允许的跨域来源
CORS_ORIGIN=https://${DOMAIN}

# 文件上传大小限制（MB）
MAX_FILE_SIZE=10
