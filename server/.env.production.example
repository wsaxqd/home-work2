# ==================== 生产环境配置示例 ====================
# 复制此文件为 .env.production 并填入真实配置
# 命令: cp .env.production.example .env.production

# ==================== 基础配置 ====================
NODE_ENV=production
PORT=3001

# ==================== 数据库配置 ====================
DB_HOST=your-production-db-host
DB_PORT=5432
DB_NAME=qmzg_production
DB_USER=qmzg_admin
DB_PASSWORD=<请生成强随机密码>

# ==================== JWT 配置 ====================
# 使用以下命令生成密钥:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<请生成64字节随机密钥>
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=<请生成64字节随机密钥>
JWT_REFRESH_EXPIRES_IN=30d

# ==================== CORS 配置 ====================
CORS_ORIGIN=https://your-production-domain.com

# ==================== 文件上传配置 ====================
UPLOAD_DIR=/var/app/uploads
MAX_FILE_SIZE=20971520

# ==================== AI 服务提供商选择 ====================
AI_PROVIDER=dify

# ==================== Dify AI 配置 ====================
DIFY_API_URL=https://api.dify.ai/v1
DIFY_API_KEY=<your-dify-api-key>
DIFY_CHAT_APP_KEY=<your-chat-app-key>
DIFY_STORY_APP_KEY=<your-story-app-key>
DIFY_EMOTION_APP_KEY=<your-emotion-app-key>
DIFY_TUTORING_APP_KEY=<your-tutoring-app-key>
DIFY_TUTORING_EVALUATE_APP_KEY=<your-evaluate-app-key>
DIFY_TUTORING_SUMMARY_APP_KEY=<your-summary-app-key>
DIFY_TIMEOUT=30000

# ==================== DeepSeek AI 配置（备用） ====================
DEEPSEEK_API_KEY=<your-deepseek-api-key>
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_TIMEOUT=30000

# ==================== 智谱 AI 配置（备用） ====================
ZHIPU_API_KEY=<your-zhipu-api-key>
ZHIPU_API_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_TIMEOUT=30000

# ==================== 腾讯云服务配置 ====================
TENCENT_SECRET_ID=<your-tencent-secret-id>
TENCENT_SECRET_KEY=<your-tencent-secret-key>
TENCENT_REGION=ap-guangzhou

# ==================== 邮件服务配置 ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@your-domain.com
SMTP_PASSWORD=<your-email-password>
EMAIL_FROM=启蒙之光 <noreply@your-domain.com>

# ==================== Redis 配置（推荐） ====================
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=<your-redis-password>

# ==================== 日志配置 ====================
LOG_LEVEL=info
LOG_DIR=/var/app/logs

# ==================== 安全配置 ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=<your-session-secret>
