# ============================================================
# 启蒙之光 - 服务器环境变量配置示例
# 使用方法：复制此文件为 .env，并填写真实值
# 警告：不要将包含真实密码的 .env 文件提交到 Git！
# ============================================================

# ==================== 服务器配置 ====================
PORT=3001
NODE_ENV=development

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qmzg
DB_USER=admin
DB_PASSWORD=CHANGE-THIS-TO-STRONG-PASSWORD

# ==================== JWT配置 ====================
# 生成强密钥：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE-THIS-TO-RANDOM-64-CHAR-HEX-STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE-THIS-TO-RANDOM-64-CHAR-HEX-STRING
JWT_REFRESH_EXPIRES_IN=30d

# ==================== 文件上传配置 ====================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ==================== CORS配置 ====================
CORS_ORIGIN=http://localhost:5173

# ==================== Dify AI配置 ====================
# 访问 https://cloud.dify.ai 创建应用并获取密钥
# 详细配置指南: ../docs/SECURITY_SETUP.md
DIFY_API_URL=https://api.dify.ai/v1
DIFY_API_KEY=app-YOUR-API-KEY-HERE
DIFY_CHAT_APP_KEY=app-YOUR-CHAT-APP-KEY
DIFY_STORY_APP_KEY=app-YOUR-STORY-APP-KEY
DIFY_EMOTION_APP_KEY=app-YOUR-EMOTION-APP-KEY
DIFY_TUTORING_APP_KEY=app-YOUR-TUTORING-APP-KEY
DIFY_TUTORING_EVALUATE_APP_KEY=app-YOUR-EVALUATE-APP-KEY
DIFY_TUTORING_SUMMARY_APP_KEY=app-YOUR-SUMMARY-APP-KEY
DIFY_TIMEOUT=30000

# ==================== 腾讯云配置 ====================
TENCENT_SECRET_ID=YOUR-SECRET-ID
TENCENT_SECRET_KEY=YOUR-SECRET-KEY
TENCENT_OCR_REGION=ap-guangzhou

# ==================== 邮件服务配置 ====================
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_USER=noreply@example.com
EMAIL_PASSWORD=YOUR-EMAIL-PASSWORD
EMAIL_FROM=启蒙之光 <noreply@example.com>

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== OSS 配置 ====================
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=YOUR-ACCESS-KEY-ID
OSS_ACCESS_KEY_SECRET=YOUR-ACCESS-KEY-SECRET
OSS_BUCKET=YOUR-BUCKET-NAME

# ==================== 监控配置 ====================
SENTRY_DSN=YOUR-SENTRY-DSN

# ==================== 日志配置 ====================
LOG_LEVEL=debug

# ============================================================
# 安全提示：
# 1. 所有密码长度应 >= 16 字符
# 2. JWT 密钥应使用 64 字符的十六进制字符串
# 3. 使用强随机密码生成器
# 4. 定期轮换密钥
# 5. 不要在代码中硬编码密钥
# 6. 查看完整安全配置指南：../docs/SECURITY_SETUP.md
# ============================================================

