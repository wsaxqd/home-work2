# ============================================================
# 启蒙之光 (QMZG) - 生产环境配置模板
# ============================================================
# 重要：将此文件复制为 .env.production，并使用真实值替换占位符
# 警告：不要将此文件提交到 Git！
# ============================================================

# === 数据库配置 ===
NODE_ENV=production
DB_HOST=postgres
DB_PORT=5432
DB_NAME=qmzg_prod
DB_USER=qmzg_admin
# 使用强密码（最少16字符）
DB_PASSWORD=YOUR_STRONG_DB_PASSWORD_HERE

# === JWT 密钥（使用 openssl rand -hex 64 生成的新密钥）===
# 【新生成的密钥 - 必须使用新值，不要重复使用旧密钥】
JWT_SECRET=GENERATE_NEW_KEY_USING_openssl_rand_-hex_64
JWT_REFRESH_SECRET=GENERATE_NEW_KEY_USING_openssl_rand_-hex_64
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# === Session 密钥 ===
SESSION_SECRET=GENERATE_NEW_KEY_USING_openssl_rand_-hex_64

# === 服务器配置 ===
PORT=3000
API_PREFIX=/api

# === 域名配置 ===
DOMAIN=qmzgai.com
CORS_ORIGIN=https://qmzgai.com,https://www.qmzgai.com,http://106.53.44.162

# === 文件上传配置 ===
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# === AI 服务配置 ===
# Dify AI - 需要替换为实际的 API 密钥
DIFY_API_KEY=YOUR_DIFY_API_KEY
DIFY_API_URL=https://api.dify.ai/v1
DIFY_CHAT_APP_KEY=YOUR_DIFY_CHAT_APP_KEY
DIFY_STORY_APP_KEY=YOUR_DIFY_STORY_APP_KEY
DIFY_EMOTION_APP_KEY=YOUR_DIFY_EMOTION_APP_KEY
DIFY_TUTORING_APP_KEY=YOUR_DIFY_TUTORING_APP_KEY
DIFY_TIMEOUT=30000

# DeepSeek AI - 需要替换为实际的 API 密钥
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
DEEPSEEK_API_URL=https://api.deepseek.com

# 智谱 GLM - 需要替换为实际的 API 密钥
ZHIPU_API_KEY=YOUR_ZHIPU_API_KEY
ZHIPU_API_URL=https://open.bigmodel.cn/api/paas/v4

# === 腾讯云服务配置 ===
# OCR 识别 - 需要替换为实际的凭证
TENCENT_SECRET_ID=YOUR_TENCENT_SECRET_ID
TENCENT_SECRET_KEY=YOUR_TENCENT_SECRET_KEY
TENCENT_OCR_REGION=ap-guangzhou

# === 邮件服务配置 ===
# 使用 QQ 邮箱或企业邮箱
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=YOUR_EMAIL@qq.com
SMTP_PASSWORD=YOUR_APP_SPECIFIC_PASSWORD
SMTP_FROM=启蒙之光 <YOUR_EMAIL@qq.com>

# === 日志配置 ===
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# === 安全配置 ===
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=10

# === Docker 镜像配置 ===
REGISTRY_URL=ccr.ccs.tencentyun.com
REGISTRY_NAMESPACE=qmzg-ai-edu
VERSION=v1.0.0

# === Docker 端口配置 ===
HTTP_PORT=80
HTTPS_PORT=443
SSL_CERT_PATH=./ssl

# ============================================================
# 配置说明
# ============================================================
#
# 1. 数据库密码
#    使用强随机密码生成器：openssl rand -base64 16
#    最少长度：16 字符
#    包含：大小写字母、数字、特殊字符
#
# 2. JWT 密钥（必须生成新密钥）
#    生成方法：openssl rand -hex 64
#    这些密钥用于用户会话管理
#    永远不要在多个环境间共用
#    安全注意：不要在文档或日志中显示完整密钥
#
# 3. AI 服务密钥
#    这些都是第三方服务的密钥
#    需要从各服务提供商的管理后台获取
#    - Dify: https://cloud.dify.ai
#    - DeepSeek: https://platform.deepseek.com
#    - 智谱: https://open.bigmodel.cn
#
# 4. 腾讯云 OCR
#    需要在腾讯云控制台获取 SecretId 和 SecretKey
#    用于图片文字识别功能
#
# 5. 邮件配置
#    使用 QQ 邮箱时：
#    - SMTP_USER: 你的QQ邮箱地址
#    - SMTP_PASSWORD: 16位授权码（不是QQ密码！）
#    获取授权码：QQ邮箱 → 设置 → 账户 → POP3/IMAP服务
#
# ============================================================
# 安全提示
# ============================================================
#
# ✓ 所有密码长度应 >= 16 字符
# ✓ JWT 密钥应 >= 32 字符（使用 openssl rand -hex 64 生成）
# ✓ 使用强随机密码生成器
# ✓ 定期轮换密钥（建议每3-6个月）
# ✓ 不要在代码中硬编码密钥
# ✓ 不要将此文件提交到 Git
# ✓ 不要在文档或日志中显示完整密钥
# ✓ 仅在生产服务器上设置此文件
# ✓ 限制文件权限：chmod 600 .env.production
#
# ============================================================
